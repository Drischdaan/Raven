include_guard(GLOBAL)

function(raven_enable_sanitizers target enable_asan enable_ubsan enable_tsan enable_lsan)
  if(CMAKE_CXX_COMPILER_ID MATCHES ".*Clang" OR CMAKE_CXX_COMPILER_ID STREQUAL "GNU")
    set(sanitizers "")

    if(enable_asan)
      list(APPEND sanitizers "address")
    endif()
    if(enable_ubsan)
      list(APPEND sanitizers "undefined")
    endif()
    if(enable_lsan)
      list(APPEND sanitizers "leak")
    endif()
    if(enable_tsan)
      if(enable_asan OR enable_lsan)
        message(WARNING
          "Thread sanitizer is incompatible with the address/leak sanitizers; not enabling TSan.")
      else()
        list(APPEND sanitizers "thread")
      endif()
    endif()

    list(JOIN sanitizers "," list_of_sanitizers)

    if(list_of_sanitizers)
      target_compile_options(${target} INTERFACE -fsanitize=${list_of_sanitizers})
      target_link_options(${target} INTERFACE -fsanitize=${list_of_sanitizers})
    endif()
  elseif(MSVC)
    if(enable_ubsan OR enable_tsan OR enable_lsan)
      message(WARNING "MSVC only supports the address sanitizer; ignoring the others.")
    endif()
    if(enable_asan)
      target_compile_options(${target} INTERFACE /fsanitize=address)
    endif()
  endif()
endfunction()
