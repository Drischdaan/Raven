root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{h,hpp,inl,c,cc,cpp,cxx}]
indent_style = tab
tab_width = 4
indent_size = tab

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[{CMakeLists.txt,*.cmake}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[.clang-{format,tidy}]
indent_style = space
indent_size = 2

[*.{sh,command}]
indent_style = space
indent_size = 2
end_of_line = lf

[*.{bat,cmd}]
indent_style = space
indent_size = 4
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false
indent_size = 2
